{{ 'section-koat-editorial.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="koat-editorial page-width section-{{ section.id }}-padding">
  {%- if section.settings.heading != blank -%}
    <h2 class="koat-editorial__section-heading">{{ section.settings.heading }}</h2>
  {%- endif -%}
  <div class="koat-editorial__grid">
    {%- for block in section.blocks -%}
      {%- if block.type == 'panel' -%}
        <div class="koat-editorial__panel koat-editorial__panel--{{ block.settings.tone }}{% if block.settings.image != blank and block.settings.image.aspect_ratio %} koat-editorial__panel--image{% endif %}" {{ block.shopify_attributes }}>
          {%- if block.settings.image != blank and block.settings.image.aspect_ratio -%}
            {{
              block.settings.image
              | image_url: width: 900
              | image_tag: widths: '450, 600, 900', sizes: '(min-width: 750px) 45vw, 90vw', class: 'koat-editorial__image'
            }}
          {%- else -%}
            {%- if block.settings.badge_text != blank -%}
              <span class="koat-badge koat-badge--ink">{{ block.settings.badge_text | escape }}</span>
            {%- endif -%}
            {%- if block.settings.heading != blank -%}
              <h3 class="koat-editorial__heading">{{ block.settings.heading }}</h3>
            {%- endif -%}
            {%- if block.settings.body != blank -%}
              <div class="koat-editorial__body rte">{{ block.settings.body }}</div>
            {%- endif -%}
            {%- if block.settings.heading_2 != blank -%}
              <div class="koat-editorial__content-divider"></div>
              {%- if block.settings.badge_text_2 != blank -%}
                <span class="koat-badge koat-badge--ink">{{ block.settings.badge_text_2 | escape }}</span>
              {%- endif -%}
              <h3 class="koat-editorial__heading">{{ block.settings.heading_2 }}</h3>
              {%- if block.settings.body_2 != blank -%}
                <div class="koat-editorial__body rte">{{ block.settings.body_2 }}</div>
              {%- endif -%}
            {%- endif -%}
          {%- endif -%}
        </div>
      {%- endif -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "KOAT Editorial",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Section heading",
      "default": "why is KOAT the G.O.A.T?"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "panel",
      "name": "Panel",
      "settings": [
        {
          "type": "select",
          "id": "tone",
          "label": "Background tone",
          "options": [
            { "value": "leaf", "label": "Sage" },
            { "value": "cream-deep", "label": "Cream deep" },
            { "value": "banana", "label": "Banana" },
            { "value": "ink", "label": "Ink" }
          ],
          "default": "cream-deep"
        },
        {
          "type": "text",
          "id": "badge_text",
          "label": "Badge text",
          "default": "Made with real ingredients"
        },
        {
          "type": "inline_richtext",
          "id": "heading",
          "label": "Heading",
          "default": "oats you can see, fruit you can taste"
        },
        {
          "type": "richtext",
          "id": "body",
          "label": "Body text",
          "default": "<p>Whole rolled oats, real fruit, and nothing you can't pronounce. No funny business, no fillers.</p>"
        },
        {
          "type": "header",
          "content": "Second content block"
        },
        {
          "type": "text",
          "id": "badge_text_2",
          "label": "Badge text"
        },
        {
          "type": "inline_richtext",
          "id": "heading_2",
          "label": "Heading"
        },
        {
          "type": "richtext",
          "id": "body_2",
          "label": "Body text"
        },
        {
          "type": "header",
          "content": "Image panel"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image (fills panel — leave blank to show text)"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "KOAT Editorial",
      "blocks": [
        {
          "type": "panel",
          "settings": {
            "tone": "leaf",
            "badge_text": "The kefir difference",
            "heading": "billions of live cultures, in a bar",
            "body": "<p>We bake real kefir into every batch — so each bar carries the same gut-friendly cultures you'd find in the fridge aisle, minus the spoon.</p>"
          }
        },
        {
          "type": "panel",
          "settings": {
            "tone": "cream-deep",
            "badge_text": "Made with real ingredients",
            "heading": "oats you can see, fruit you can taste",
            "body": "<p>Whole rolled oats, real fruit, and nothing you can't pronounce. No funny business, no fillers.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
