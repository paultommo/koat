{{ 'section-koat-guarantee.css' | asset_url | stylesheet_tag }}

<div class="koat-guarantee">
  <div class="page-width">
    {%- if section.settings.heading != blank -%}
      <h2 class="koat-guarantee__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="koat-guarantee__grid">
      {%- for block in section.blocks -%}
        <div class="koat-guarantee__box" {{ block.shopify_attributes }}>
          <div class="koat-guarantee__icon">
            {%- case block.settings.icon -%}
              {%- when 'money' -%}
                <img src="https://cdn.shopify.com/s/files/1/0974/5019/7292/files/KOAT-goat-cash.png" alt="Goat with cash" width="120" height="120" loading="lazy">
              {%- when 'headset' -%}
                <img src="https://cdn.shopify.com/s/files/1/0974/5019/7292/files/KOAT-goat-assistant.png" alt="Goat assistant" width="120" height="120" loading="lazy">
              {%- when 'bars' -%}
                <img src="https://cdn.shopify.com/s/files/1/0974/5019/7292/files/KOAT-goat-refund.png" alt="Goat refund" width="120" height="120" loading="lazy">
            {%- endcase -%}
          </div>
          <p class="koat-guarantee__title">{{ block.settings.title | escape }}</p>
        </div>
      {%- endfor -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Guarantee",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "want a refund?"
    }
  ],
  "blocks": [
    {
      "type": "box",
      "name": "Box",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "options": [
            { "value": "money", "label": "Goat eating cash" },
            { "value": "headset", "label": "Goat with headset" },
            { "value": "bars", "label": "Goat holding bars" }
          ],
          "default": "money"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Guarantee",
      "blocks": [
        {
          "type": "box",
          "settings": {
            "icon": "money",
            "title": "100% Money Back Guarantee"
          }
        },
        {
          "type": "box",
          "settings": {
            "icon": "headset",
            "title": "Speak to one of our world class assistants"
          }
        },
        {
          "type": "box",
          "settings": {
            "icon": "bars",
            "title": "Easily swap your bundle"
          }
        }
      ]
    }
  ]
}
{% endschema %}
