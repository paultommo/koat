{{ 'section-koat-newsletter.css' | asset_url | stylesheet_tag }}

<div class="koat-newsletter">
  <div class="page-width koat-newsletter__inner">
    <h2 class="koat-newsletter__heading">{{ section.settings.heading }}</h2>
    {%- if section.settings.body != blank -%}
      <p class="koat-newsletter__body">{{ section.settings.body }}</p>
    {%- endif -%}

    {%- form 'customer', id: 'koat-newsletter-form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <div class="koat-newsletter__form">
        <label for="koat-newsletter-email" class="visually-hidden">Email address</label>
        <input
          id="koat-newsletter-email"
          class="koat-newsletter__input"
          type="email"
          name="contact[email]"
          autocomplete="email"
          placeholder="{{ section.settings.placeholder }}"
          required
        >
        <button type="submit" class="koat-newsletter__button button">
          {{ section.settings.button_label }}
        </button>
      </div>
      {%- if form.posted_successfully? -%}
        <p class="koat-newsletter__success">You're in! Check your inbox for your 10% off code.</p>
      {%- endif -%}
      {%- if form.errors -%}
        <p class="koat-newsletter__error">{{ form.errors | default_errors }}</p>
      {%- endif -%}
    {%- endform -%}
  </div>
</div>

{% schema %}
{
  "name": "Newsletter",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading",
      "default": "want special offers, new flavours and more?"
    },
    {
      "type": "text",
      "id": "body",
      "label": "Body text",
      "default": "Then sign up for our delicious mailing list below. AND get a 10% discount off your first order too"
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Input placeholder",
      "default": "your email address"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Subscribe"
    }
  ],
  "presets": [
    {
      "name": "Newsletter"
    }
  ]
}
{% endschema %}
