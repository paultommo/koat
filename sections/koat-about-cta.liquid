<div class="koat-about-cta color-{{ section.settings.color_scheme }}">
  {%- if section.settings.image != blank -%}
    <img
      class="koat-about-cta__image"
      src="{{ section.settings.image | image_url: width: 900 }}"
      alt="{{ section.settings.image.alt | escape }}"
      width="900"
      height="600"
      loading="lazy"
    >
  {%- else -%}
    <div class="koat-about-cta__image koat-about-cta__image--placeholder"></div>
  {%- endif -%}
  <div class="koat-about-cta__body">
    {%- if section.settings.heading != blank -%}
      <p class="koat-about-cta__heading">{{ section.settings.heading }}</p>
    {%- endif -%}
    {%- if section.settings.button_label != blank -%}
      <a href="{{ section.settings.button_url }}" class="button button--primary koat-about-cta__btn">
        {{ section.settings.button_label }}
      </a>
    {%- endif -%}
  </div>
</div>

{% schema %}
{
  "name": "About CTA",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Bundle image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Subscribe now and get 25% off your first order."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop bundles"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button link"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Colour scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "About CTA"
    }
  ]
}
{% endschema %}
